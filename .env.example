# AI Provider: "openai" or "gemini" (default: openai)
AI_PROVIDER=openai

# OpenAI config (used when AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini config (used when AI_PROVIDER=gemini)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model override (optional — auto-detected based on provider)
# OpenAI default: gpt-4o | Gemini default: gemini-2.0-flash
AI_MODEL=

# Telegram bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Rate limiting
RATE_LIMIT_PER_HOUR=20
